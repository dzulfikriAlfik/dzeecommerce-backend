# ──────────────────────────────────────────────
# Dzeecommerce Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.development, .env.test, or .env.production
# and fill in the values for your environment.

NODE_ENV=development
PORT=4000

# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=
DB_NAME=dbName

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── JWT ──
JWT_ACCESS_SECRET=change-me-at-least-16-chars
JWT_REFRESH_SECRET=change-me-at-least-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Logging ──
LOG_LEVEL=debug

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
