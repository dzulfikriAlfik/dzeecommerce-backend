# ──────────────────────────────────────
# Dzeecommerce Backend — Development Dockerfile
# Hot-reload with tsx watch
# ──────────────────────────────────────

FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY tsconfig.json ./
COPY prisma ./prisma/
RUN npx prisma generate

COPY src ./src/

# Create logs directory
RUN mkdir -p logs

EXPOSE 4000

CMD ["npx", "tsx", "watch", "src/index.ts"]
